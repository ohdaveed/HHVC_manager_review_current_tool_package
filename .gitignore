# WSL/Windows mark-of-the-web download artifacts
*:Zone.Identifier

# npm
node_modules/

# Build artifacts - regenerate with `bun run build`
manager-review-single-file.html
single-file-export-current-source.html
data/page_inventory.json
data/page_inventory.csv

# Netlify deploy bundle (root only). Anchored with a leading slash on purpose:
# a bare "dist/" would also match forms/mosquito-workshop-request/dist/, whose
# built output IS committed (build:netlify copies it verbatim instead of
# running Vite). An unanchored pattern previously swallowed that sub-app's
# rebuilt hashed JS asset and shipped a form shell that never hydrated.
/dist/
.netlify

# Playwright
test-results/
playwright-report/

# OS files
.DS_Store
Thumbs.db

# Local scratch / one-off migration scripts and repo-dump artifacts. Root
# scratch files (scratch.js, fix_*.py, etc.) and repomix output were once
# committed by accident; keep them out of the tree — real tooling belongs
# in build_scripts/.
scratch*.js
repomix-output.xml

# Superpowers brainstorming scratch (mockups, session state)
.superpowers/

# Superpowers git worktrees (isolated workspaces for plan execution)
.worktrees/

# Google service account keys (never commit)
*-service-account*.json
google-service-account.json
.env.local

# Playwright MCP scratch console logs/snapshots (not part of source, see CLAUDE.md)
.playwright-mcp/

# Local tool settings/credentials
.poolside/

# Stray Windows-absolute-path artifacts written into the repo root by a
# Lighthouse MCP tool bug (e.g. "C:\Users\<name>\AppData\...\lighthouse.*"
# created verbatim as a literal directory name since WSL doesn't parse
# backslashes as path separators). Not real repo content if it recurs.
/C:*

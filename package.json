{
  "name": "hhvc-manager-review-mockup-tool",
  "private": true,
  "devDependencies": {
    "@sfgov/design-system": "0.0.1",
    "csv-writer": "^1.6.0",
    "zod": "^3.24.1",
    "prettier": "^3.5.1"
  },
  "scripts": {
    "dev": "bash start-dev.sh",
    "start": "bun run server.ts",
    "validate": "bun build_scripts/validate.js",
    "export": "bun build_scripts/extract-pages.js",
    "build": "bun run validate && bun run export && bun run build:workshop-form && bun build_scripts/build-single-file.js",
    "build:workshop-form": "bun install --cwd forms/mosquito-workshop-request && bun run --cwd forms/mosquito-workshop-request build",
    "build:netlify": "node build_scripts/validate.js && node build_scripts/build-netlify-dist.js",
    "format": "prettier --write \"**/*.{js,ts,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md,css,html}\"",
    "test": "bun test"
  }
}

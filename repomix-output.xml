<file path="css/ux-improvements.css">
/* Manager review UX/UI enhancements.
   These styles layer on top of the existing mockup tool without changing page content. */

:root {
  --ux-panel-bg: var(--sfds-white);
  --ux-panel-border: var(--sfds-border);
  --ux-soft-bg: var(--sfds-slate-5);
  --ux-warning-bg: var(--sfds-warning-bg);
  --ux-warning-border: var(--sfds-warning-border);
  --ux-danger-bg: var(--sfds-danger-bg);
  --ux-danger-border: var(--sfds-danger-border);
  --content-max: 65ch;
}

.canvas-toolbar {
  align-items: center;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.review-sticky-bar {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.55rem;
  min-width: 0;
  padding: 0.45rem 0.65rem;
  border: 1px solid var(--ux-panel-border);
  border-radius: var(--radius);
  background: var(--ux-panel-bg);
}

.review-sticky-bar-main {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.45rem;
  min-width: 0;
}

.review-sticky-bar-title {
  margin: 0;
  font-size: 0.86rem;
  font-weight: 800;
  color: var(--sfds-slate-1);
  line-height: 1.25;
  max-width: 28ch;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-sticky-bar-progress {
  color: var(--sfds-slate-3);
  font-size: 0.78rem;
  font-weight: 700;
  white-space: nowrap;
}

.review-sticky-bar-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.35rem;
}

.review-sticky-btn {
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  background: var(--sfds-white);
  color: var(--sfds-slate-2);
  cursor: pointer;
  font: inherit;
  font-size: 0.76rem;
  font-weight: 700;
  line-height: 1.2;
  min-height: 2rem;
  padding: 0.35rem 0.6rem;
}

.review-sticky-btn:hover,
.review-sticky-btn:focus-visible {
  border-color: var(--sfds-action-blue);
  background: var(--sfds-blue-soft-bg);
  color: var(--sfds-action-blue-hover);
}

.review-sticky-btn.primary {
  border-color: var(--sfds-action-blue);
  background: var(--sfds-action-blue);
  color: var(--sfds-white);
}

.review-sticky-btn.primary:hover,
.review-sticky-btn.primary:focus-visible {
  background: var(--sfds-action-blue-hover);
  border-color: var(--sfds-action-blue-hover);
  color: var(--sfds-white);
}

.review-workspace {
  width: 100%;
  max-width: var(--page-max);
  margin: 0.85rem auto 0;
  border: 1px solid var(--ux-panel-border);
  border-radius: 12px;
  background: var(--ux-panel-bg);
  box-shadow: 0 4px 14px rgba(0, 43, 72, 0.08);
  overflow: hidden;
}

.review-workspace-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  border-bottom: 1px solid var(--sfds-border);
  background: var(--ux-soft-bg);
}

.review-workspace-tab {
  border: 0;
  border-bottom: 3px solid transparent;
  background: transparent;
  color: var(--sfds-slate-3);
  cursor: pointer;
  font: inherit;
  font-size: 0.82rem;
  font-weight: 700;
  min-height: 2.5rem;
  padding: 0.55rem 0.95rem;
}

.review-workspace-tab:hover,
.review-workspace-tab:focus-visible {
  color: var(--sfds-action-blue);
  background: var(--sfds-white);
}

.review-workspace-tab[aria-selected='true'] {
  color: var(--sfds-action-blue);
  border-bottom-color: var(--sfds-action-blue);
  background: var(--sfds-white);
}

.review-workspace-panel {
  max-height: min(52vh, 560px);
  overflow: auto;
}

.review-workspace-panel[hidden] {
  display: none !important;
}

.review-queue {
  padding: 0.85rem 1rem 1rem;
}

.review-queue-header {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.65rem;
  margin-bottom: 0.75rem;
}

.review-queue-header h3 {
  margin: 0;
  font-size: 1rem;
}

.review-queue-subtitle {
  margin: 0.2rem 0 0;
  color: var(--sfds-slate-3);
  font-size: 0.78rem;
  line-height: 1.35;
}

.review-queue-progress {
  flex: 1;
  min-width: 10rem;
}

.review-queue-progress-bar {
  height: 0.45rem;
  border-radius: 999px;
  background: var(--sfds-slate-5);
  overflow: hidden;
}

.review-queue-progress-fill {
  display: block;
  height: 100%;
  border-radius: 999px;
  background: var(--sfds-green);
  transition: width 0.2s ease;
}

.review-queue-progress-label {
  display: block;
  margin-top: 0.25rem;
  color: var(--sfds-slate-3);
  font-size: 0.76rem;
  font-weight: 600;
}

.review-queue-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.65rem;
}

.review-queue-overview {
  margin-bottom: 0.75rem;
}

.review-queue-kpis {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.5rem;
}

.review-queue-kpi {
  padding: 0.65rem 0.75rem;
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  background: var(--ux-soft-bg);
}

.review-queue-kpi-label {
  display: block;
  margin-bottom: 0.18rem;
  color: var(--sfds-slate-3);
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.review-queue-kpi-value {
  display: block;
  color: var(--sfds-slate-1);
  font-size: 1rem;
  font-weight: 800;
}

.review-queue-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(12rem, 15rem);
  gap: 0.65rem;
  margin-bottom: 0.75rem;
}

.review-queue-search,
.review-queue-sort {
  display: grid;
  gap: 0.3rem;
}

.review-queue-control-label {
  color: var(--sfds-slate-3);
  font-size: 0.72rem;
  font-weight: 700;
}

.review-queue-toolbar select {
  width: 100%;
  min-height: 2.9rem;
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  padding: 0.7rem 0.85rem;
  font: inherit;
  color: var(--sfds-slate-1);
  background: var(--sfds-white);
}

.review-queue-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.65rem;
}

.review-queue-filter {
  border: 1px solid var(--sfds-border);
  border-radius: 999px;
  background: var(--sfds-white);
  color: var(--sfds-slate-2);
  cursor: pointer;
  font: inherit;
  font-size: 0.74rem;
  font-weight: 700;
  min-height: 1.85rem;
  padding: 0.2rem 0.6rem;
}

.review-queue-filter:hover,
.review-queue-filter:focus-visible {
  border-color: var(--sfds-action-blue);
  color: var(--sfds-action-blue);
}

.review-queue-filter[aria-pressed='true'] {
  border-color: var(--sfds-action-blue);
  background: var(--sfds-blue-soft-bg);
  color: var(--sfds-action-blue-hover);
}

.review-queue-bulk {
  display: grid;
  gap: 0.55rem;
  margin-bottom: 0.75rem;
  padding: 0.7rem 0.75rem;
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  background: var(--ux-soft-bg);
}

.review-queue-bulk-main,
.review-queue-bulk-actions,
.review-queue-import {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4rem;
}

.review-queue-select-all {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  color: var(--sfds-slate-2);
  font-size: 0.78rem;
  font-weight: 700;
}

.review-queue-bulk-count {
  color: var(--sfds-slate-3);
  font-size: 0.76rem;
  font-weight: 700;
}

.review-queue-checkbox {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 0.15rem;
  cursor: pointer;
}

.review-queue-checkbox input {
  width: 1rem;
  height: 1rem;
}

.review-queue-subtitle kbd {
  display: inline-block;
  min-width: 1.2rem;
  padding: 0.05rem 0.3rem;
  border: 1px solid var(--sfds-border);
  border-radius: 0.25rem;
  background: var(--sfds-white);
  font-family: inherit;
  font-size: 0.72rem;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.review-queue-row-title {
  display: block;
  color: var(--sfds-slate-1);
  font-size: 0.88rem;
  font-weight: 800;
  line-height: 1.25;
}

.review-queue-row-meta {
  display: block;
  margin-top: 0.12rem;
  color: var(--sfds-slate-3);
  font-size: 0.72rem;
  font-weight: 600;
  line-height: 1.3;
}

.review-queue-row-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem 0.75rem;
  margin-top: 0.22rem;
  color: var(--sfds-slate-3);
  font-size: 0.72rem;
  line-height: 1.3;
}

.review-queue-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.45rem;
}

.review-queue-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.45rem;
}

.review-queue-action {
  border: 1px solid var(--sfds-border);
  border-radius: 999px;
  background: var(--sfds-white);
  color: var(--sfds-action-blue);
  cursor: pointer;
  font: inherit;
  font-size: 0.7rem;
  font-weight: 800;
  line-height: 1.2;
  padding: 0.28rem 0.6rem;
}

.review-queue-action:hover,
.review-queue-action:focus-visible {
  border-color: var(--sfds-action-blue);
  background: var(--sfds-blue-soft-bg);
}

.review-queue-action:disabled {
  cursor: not-allowed;
  opacity: 0.55;
  background: var(--sfds-slate-6);
  color: var(--sfds-slate-3);
}

.review-queue-empty {
  padding: 1rem;
  border: 1px dashed var(--sfds-border);
  border-radius: var(--radius);
  background: var(--ux-soft-bg);
}

.review-queue-empty p {
  margin: 0 0 0.6rem;
  color: var(--sfds-slate-2);
}

.review-queue-table-wrap {
  overflow-x: auto;
}

.review-queue-table {
  width: 100%;
  border-collapse: collapse;
}

.review-queue-table th {
  padding: 0.5rem 0.6rem;
  border-bottom: 2px solid var(--sfds-border);
  color: var(--sfds-slate-3);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-align: left;
  text-transform: uppercase;
  white-space: nowrap;
}

.review-queue-table td {
  padding: 0.55rem 0.6rem;
  vertical-align: top;
}

.review-queue-table-row {
  border-bottom: 1px solid var(--sfds-border);
}

.review-queue-table-row:hover {
  background: var(--sfds-blue-soft-bg);
}

.review-queue-table-row.is-current {
  box-shadow: inset 3px 0 0 var(--sfds-action-blue);
}

.review-queue-table-row.is-selected {
  background: var(--sfds-blue-soft-bg);
}

.review-queue-table-select {
  width: 2rem;
}

.review-queue-table-checks,
.review-queue-table-decision,
.review-queue-table-owner,
.review-queue-table-updated {
  white-space: nowrap;
}

.review-sticky-bar-filter {
  color: var(--sfds-slate-3);
  font-size: 0.74rem;
  font-weight: 700;
  white-space: nowrap;
}

.review-checks-panel {
  width: 100%;
}

.review-dashboard {
  width: 100%;
  max-width: var(--page-max);
  margin: 0 auto;
  overflow: hidden;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  min-height: 1.75rem;
  border-radius: 999px;
  padding: 0.22rem 0.65rem;
  font-size: 0.78rem;
  font-weight: 700;
  border: 1px solid var(--sfds-border);
  background: var(--sfds-white);
  color: var(--sfds-slate-2);
}

.status-chip.pass {
  border-color: var(--sfds-success-border);
  background: var(--sfds-success-bg);
  color: var(--sfds-success-text);
}

.status-chip.warn {
  border-color: var(--ux-warning-border);
  background: var(--ux-warning-bg);
  color: var(--sfds-warning-text);
}

.status-chip.fail {
  border-color: var(--ux-danger-border);
  background: var(--ux-danger-bg);
  color: var(--sfds-danger-text);
}

.compliance-panel {
  padding: 0.9rem 1rem 1rem;
}

.compliance-panel h3 {
  margin: 0 0 0.55rem;
  font-size: 1rem;
}

.compliance-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.55rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.compliance-item {
  display: grid;
  grid-template-columns: 1.25rem minmax(0, 1fr);
  gap: 0.5rem;
  align-items: start;
  padding: 0.65rem;
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  background: var(--ux-soft-bg);
  cursor: help;
}

.compliance-item::before {
  content: '';
  width: 0.9rem;
  height: 0.9rem;
  margin-top: 0.22rem;
  border-radius: 50%;
  background: var(--sfds-slate-4);
}

.compliance-item.pass::before {
  background: var(--sfds-green);
}

.compliance-item.warn::before {
  background: var(--sfds-warning-border);
}

.compliance-rule {
  display: block;
  color: var(--sfds-slate-1);
  font-size: 0.88rem;
  font-weight: 800;
  line-height: 1.25;
}

.compliance-detail {
  display: block;
  margin-top: 0.15rem;
  color: var(--sfds-slate-3);
  font-size: 0.78rem;
  line-height: 1.35;
}

.review-queue input[type='search'] {
  width: 100%;
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  padding: 0.85rem 0.9rem;
  font: inherit;
  color: var(--sfds-slate-1);
  background: var(--sfds-white);
}

.review-queue input[type='search']:focus {
  outline: 3px solid rgba(42, 96, 175, 0.25);
  outline-offset: 2px;
}

.tool-btn.copy-summary {
  background: var(--sfds-slate-1);
  border-color: var(--sfds-slate-1);
}

.tool-btn.copy-summary:hover {
  background: var(--sfds-slate-2);
  border-color: var(--sfds-slate-2);
}

.review-decision-note {
  margin: 0.45rem 0 0;
  color: var(--sfds-slate-3);
  font-size: 0.78rem;
  line-height: 1.35;
}

.decision-quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin: 0.45rem 0 0.2rem;
}

.decision-chip {
  border: 1px solid var(--sfds-border);
  border-radius: 999px;
  background: var(--sfds-white);
  color: var(--sfds-slate-2);
  cursor: pointer;
  font: inherit;
  font-size: 0.74rem;
  font-weight: 700;
  line-height: 1.2;
  min-height: 1.9rem;
  padding: 0.25rem 0.65rem;
}

.decision-chip:hover,
.decision-chip:focus-visible {
  border-color: var(--sfds-action-blue);
  color: var(--sfds-action-blue);
}

.decision-chip[aria-pressed='true'] {
  border-color: var(--sfds-slate-2);
  background: var(--sfds-slate-5);
  color: var(--sfds-slate-1);
  box-shadow: inset 0 0 0 1px var(--sfds-slate-2);
}

.decision-chip.approve[aria-pressed='true'] {
  border-color: var(--sfds-success-border);
  background: var(--sfds-success-bg);
  color: var(--sfds-success-text);
  box-shadow: inset 0 0 0 1px var(--sfds-success-border);
}

.decision-chip.revise[aria-pressed='true'],
.decision-chip.block[aria-pressed='true'] {
  border-color: var(--sfds-danger-border);
  background: var(--sfds-danger-bg);
  color: var(--sfds-danger-text);
  box-shadow: inset 0 0 0 1px var(--sfds-danger-border);
}

.shortcuts-hint-button {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  border: 1px solid var(--sfds-border);
  border-radius: var(--radius);
  background: var(--sfds-white);
  color: var(--sfds-slate-2);
  cursor: pointer;
  font: inherit;
  font-size: 0.76rem;
  font-weight: 700;
  min-height: 2rem;
  padding: 0.3rem 0.6rem;
}

.shortcuts-hint-button:hover,
.shortcuts-hint-button:focus-visible {
  border-color: var(--sfds-action-blue);
  background: var(--sfds-blue-soft-bg);
  color: var(--sfds-action-blue-hover);
}

.shortcuts-hint-button kbd,
.shortcuts-dialog kbd {
  display: inline-block;
  min-width: 1.4rem;
  border: 1px solid var(--sfds-border);
  border-bottom-width: 2px;
  border-radius: 5px;
  background: var(--ux-soft-bg);
  color: var(--sfds-slate-1);
  font-family: inherit;
  font-size: 0.74rem;
  font-weight: 800;
  line-height: 1.3;
  padding: 0.08rem 0.35rem;
  text-align: center;
}

.shortcuts-dialog {
  width: min(30rem, calc(100vw - 2rem));
  border: 1px solid var(--ux-panel-border);
  border-radius: 12px;
  background: var(--ux-panel-bg);
  box-shadow: 0 18px 48px rgba(0, 43, 72, 0.28);
  padding: 1rem 1.15rem 1.15rem;
}

.shortcuts-dialog::backdrop {
  background: rgba(10, 31, 51, 0.45);
}

.shortcuts-dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}

.shortcuts-dialog-header h2 {
  margin: 0;
  font-size: 1.05rem;
}

.shortcuts-dialog-close {
  border: 1px solid var(--sfds-border);
  border-radius: 50%;
  background: var(--sfds-white);
  color: var(--sfds-slate-2);
  cursor: pointer;
  font-size: 1rem;
  font-weight: 700;
  line-height: 1;
  width: 2rem;
  height: 2rem;
}

.shortcuts-dialog-close:hover,
.shortcuts-dialog-close:focus-visible {
  border-color: var(--sfds-action-blue);
  color: var(--sfds-action-blue);
}

.shortcuts-dialog-note {
  margin: 0.4rem 0 0.75rem;
  color: var(--sfds-slate-3);
  font-size: 0.8rem;
}

.shortcuts-list {
  display: grid;
  gap: 0.45rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.shortcuts-item {
  display: grid;
  grid-template-columns: 7.5rem minmax(0, 1fr);
  gap: 0.6rem;
  align-items: baseline;
}

.shortcuts-keys {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}

.shortcuts-or {
  color: var(--sfds-slate-4);
  font-size: 0.7rem;
}

.shortcuts-description {
  color: var(--sfds-slate-2);
  font-size: 0.82rem;
  line-height: 1.35;
}

@media (max-width: 720px) {
  .review-sticky-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .review-sticky-bar-title {
    max-width: none;
    white-space: normal;
  }

  .review-sticky-bar-actions {
    justify-content: flex-start;
  }

  .review-queue-kpis,
  .compliance-list {
    grid-template-columns: 1fr;
  }

  .review-queue-toolbar {
    grid-template-columns: 1fr;
  }

  .shortcuts-item {
    grid-template-columns: 6rem minmax(0, 1fr);
  }
}

/* ==========================================================================
   Editorial Reading Column & Visual Hierarchy Updates
   ========================================================================== */

/* Vertical Rhythm */
.section {
  margin-bottom: 3rem !important;
  padding: 1.5rem 0 !important;
}

/* Digestible Data (Gestalt Principles) */
ul li,
ol li {
  margin-bottom: 0.75rem !important;
}

/* Tame the CMS Tags */
.karl-tag,
.karl-tag[data-kind='meta'],
.karl-tag[data-kind='body'],
.karl-tag[data-kind='placement'],
.karl-tag[data-kind='editor'] {
  background: var(--sfds-blue-soft-bg) !important;
  border: none !important;
  border-left: 4px solid var(--sfds-purple-border) !important;
  color: var(--sfds-slate-3) !important;
  font-size: 0.85rem !important;
  padding: 0.2rem 0.5rem !important;
  display: inline-block;
  margin: 0.2rem 0;
  border-radius: 0 4px 4px 0 !important;
}
